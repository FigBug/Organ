<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Organ</title>
    <organization>com.socalabs</organization>
    <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true"/>
    <options customize="always" require-scripts="false" rootVolumeOnly="true"/>
    <license file="EULA.rtf"/>
    <welcome    file="welcome.txt"   mime-type="text/plain"/>

    <choices-outline>
        <line choice="com.socalabs.organ.vst"/>
        <line choice="com.socalabs.organ.vst3"/>
        <line choice="com.socalabs.organ.au"/>
        <line choice="com.socalabs.organ.clap"/>
        <line choice="com.socalabs.organ.crashreporter"/>

    </choices-outline>

    <choice id="com.socalabs.organ.vst"
            title="VST"
            description="Install the VST plug-in to /Library/Audio/Plug-Ins/VST"
            visible="true">
        <pkg-ref id="com.socalabs.organ.vst.pkg"/>
    </choice>

    <choice id="com.socalabs.organ.vst3"
            title="VST3"
            description="Install the VST3 plug-in to /Library/Audio/Plug-Ins/VST3"
            visible="true">
        <pkg-ref id="com.socalabs.organ.vst3.pkg"/>
    </choice>

    <choice id="com.socalabs.organ.au"
            title="Audio Unit"
            description="Install the Audio Unit plug-in to /Library/Audio/Plug-Ins/Components"
            visible="true">
        <pkg-ref id="com.socalabs.organ.au.pkg"/>
    </choice>

    <choice id="com.socalabs.organ.clap"
            title="CLAP"
            description="Install the CLAP plug-in to /Library/Audio/Plug-Ins/CLAP"
            visible="true">
        <pkg-ref id="com.socalabs.organ.clap.pkg"/>
    </choice>

    <choice id="com.socalabs.organ.crashreporter"
            title="Crash Reporter"
            description="Install the shared crash reporter that sends crash reports to SocaLabs. Recommended; only updated if newer."
            visible="true"
            enabled="true"
            selected="true">
        <pkg-ref id="com.socalabs.organ.crashreporter.pkg"/>
    </choice>

    <pkg-ref id="com.socalabs.organ.vst.pkg"   version="0">vst.pkg</pkg-ref>
    <pkg-ref id="com.socalabs.organ.vst3.pkg"  version="0">vst3.pkg</pkg-ref>
    <pkg-ref id="com.socalabs.organ.au.pkg"    version="0">au.pkg</pkg-ref>
    <pkg-ref id="com.socalabs.organ.clap.pkg"  version="0">clap.pkg</pkg-ref>
    <pkg-ref id="com.socalabs.organ.crashreporter.pkg" version="0">reporter.pkg</pkg-ref>

</installer-gui-script>
